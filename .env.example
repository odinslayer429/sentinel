# ══════════════════════════════════════════════════════════
#  SENTINEL — Environment Configuration
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════

# ── Security ──────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# ── CORS: comma-separated list of allowed frontend origins ─
# Examples: http://localhost:3000,https://sentinel.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────
# Absolute or relative path to the SQLite database file
SENTINEL_DB_PATH=./data/sentinel_v2.db

# ── Data Directory ────────────────────────────────────────
# Directory containing all CSV source files for the pipeline
SENTINEL_DATA_DIR=./data

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── External APIs ─────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
NEWS_API_KEY=your_newsapi_key_here
